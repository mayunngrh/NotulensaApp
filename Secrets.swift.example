import Foundation

/// Build-time credentials, baked into the app binary so a distributed .app
/// works without any setup on the target Mac.
///
/// Setup: copy this file to NotulensaApp/Secrets.swift and fill in the values
/// from your OAuth Desktop client (console.cloud.google.com → Credentials).
/// NotulensaApp/Secrets.swift is gitignored — never commit real values.
enum Secrets {
    static let gdriveClientID = ""
    static let gdriveClientSecret = ""
}
